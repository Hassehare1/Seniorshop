# Poolad anslutning (transaction-mode, pgBouncer) — appens runtime på serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true&connection_limit=1"
# Direkt/session-mode — används av Prisma-migrationer (migrate deploy)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate_with: openssl rand -base64 32"
